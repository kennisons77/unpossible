# Copy to .env and fill in values. Never commit .env.

# GitHub personal access token — used by loop.sh for git push (HTTPS remotes)
# Requires: repo scope (or contents:write for fine-grained tokens)
GH_TOKEN=ghp_your_token_here

# Anthropic API key — used by Claude agent in loop.sh
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Runner sidecar auth — used by the Go runner and agent container
RUNNER_PASSWORD=change_me
RUNNER_USERNAME=runner

# Path to kiro-cli binary on host — bind-mounted into agent container
# Find with: which kiro-cli
KIRO_CLI_PATH=/usr/local/bin/kiro-cli
