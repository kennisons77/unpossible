<div class="row justify-content-center mt-5">
  <div class="col-md-5">
    <div class="card">
      <div class="card-body p-4">
        <h1 class="card-title text-center mb-4">Sign In</h1>

        <%= form_with url: session_path, method: :post do |f| %>
          <div class="mb-3">
            <%= f.label :email_address, "Email", class: "form-label" %>
            <%= f.email_field :email_address, autofocus: true, required: true, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :password, class: "form-label" %>
            <%= f.password_field :password, required: true, class: "form-control" %>
          </div>

          <%= f.submit "Sign in", class: "btn btn-primary w-100" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
