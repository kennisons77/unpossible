<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><%= @concern.name %></h1>
  <%= link_to '← Back to Concerns', concerns_path, class: 'btn btn-secondary' %>
</div>

<div class="card mb-4">
  <div class="card-header">
    <h5 class="mb-0">Concern Details</h5>
  </div>
  <div class="card-body">
    <dl class="row mb-0">
      <dt class="col-sm-3">Status</dt>
      <dd class="col-sm-9">
        <% if @concern.confirmed_at %>
          <span class="badge bg-success">Confirmed</span>
          <small class="text-muted ms-2"><%= @concern.confirmed_at.strftime('%Y-%m-%d %H:%M') %></small>
        <% else %>
          <span class="badge bg-warning text-dark">Unconfirmed (LLM-proposed)</span>
          <%= button_to 'Confirm', confirm_concern_path(@concern), method: :post, class: 'btn btn-sm btn-success ms-2' %>
        <% end %>
      </dd>

      <dt class="col-sm-3">Documents</dt>
      <dd class="col-sm-9"><%= @concern.documents.count %></dd>

      <dt class="col-sm-3">Created</dt>
      <dd class="col-sm-9"><%= @concern.created_at.strftime('%Y-%m-%d %H:%M:%S') %></dd>
    </dl>
  </div>
</div>

<h3>Documents in this Concern</h3>

<% if @documents.any? %>
  <div class="table-responsive">
    <table class="table table-hover">
      <thead>
        <tr>
          <th>ID</th>
          <th>Type</th>
          <th>Stage</th>
          <th>Confidence</th>
          <th>Created</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @documents.each do |document| %>
          <tr>
            <td><%= document.id %></td>
            <td><%= document.document_type || '—' %></td>
            <td><span class="badge bg-secondary"><%= document.stage %></span></td>
            <td>
              <% if document.confidence_score %>
                <%= number_to_percentage(document.confidence_score * 100, precision: 0) %>
              <% else %>
                —
              <% end %>
            </td>
            <td><%= document.created_at.strftime('%Y-%m-%d %H:%M') %></td>
            <td><%= link_to 'View', document_path(document), class: 'btn btn-sm btn-primary' %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="alert alert-info">
    No documents in this concern yet.
  </div>
<% end %>
