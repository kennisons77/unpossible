<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>
    <%= @concern.name %>
    <% if @concern.llm_proposed? && !@concern.confirmed? %>
      <span class="badge bg-warning">LLM Proposed</span>
    <% end %>
  </h1>
  <div>
    <% if @concern.llm_proposed? && !@concern.confirmed? %>
      <%= button_to 'Confirm Concern', confirm_concern_path(@concern), method: :patch, class: 'btn btn-success' %>
    <% end %>
    <%= link_to 'Back to Concerns', concerns_path, class: 'btn btn-secondary' %>
  </div>
</div>

<div class="card mb-4">
  <div class="card-body">
    <dl class="row mb-0">
      <dt class="col-sm-3">Status</dt>
      <dd class="col-sm-9">
        <% if @concern.confirmed? %>
          <span class="badge bg-success">Confirmed</span>
          <small class="text-muted">on <%= @concern.confirmed_at.strftime('%Y-%m-%d %H:%M') %></small>
        <% else %>
          <span class="badge bg-warning">Awaiting Confirmation</span>
        <% end %>
      </dd>

      <dt class="col-sm-3">Documents</dt>
      <dd class="col-sm-9"><%= pluralize(@concern.documents.count, 'document') %></dd>
    </dl>
  </div>
</div>

<h3>Documents</h3>

<% if @documents.any? %>
  <div class="table-responsive">
    <table class="table table-hover">
      <thead>
        <tr>
          <th>ID</th>
          <th>Type</th>
          <th>Stage</th>
          <th>Confidence</th>
          <th>Created</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @documents.each do |document| %>
          <tr>
            <td><%= document.id %></td>
            <td><%= document.document_type || '-' %></td>
            <td><span class="badge bg-<%= stage_badge_class(document.stage) %>"><%= document.stage %></span></td>
            <td><%= document.confidence_score ? number_to_percentage(document.confidence_score * 100, precision: 0) : '-' %></td>
            <td><%= time_ago_in_words(document.created_at) %> ago</td>
            <td><%= link_to 'View', document_path(document), class: 'btn btn-sm btn-primary' %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="alert alert-info">
    No documents in this concern yet.
  </div>
<% end %>
