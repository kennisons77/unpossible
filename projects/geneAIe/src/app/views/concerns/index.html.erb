<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Concerns</h1>
</div>

<% if @concerns.any? %>
  <div class="row">
    <% @concerns.each do |concern| %>
      <div class="col-md-4 mb-3">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title">
              <%= concern.name %>
              <% if concern.llm_proposed? && !concern.confirmed? %>
                <span class="badge bg-warning">LLM Proposed</span>
              <% end %>
            </h5>
            <p class="card-text text-muted">
              <%= pluralize(concern.documents.count, 'document') %>
            </p>
            <%= link_to 'View', concern_path(concern), class: 'btn btn-primary btn-sm' %>
            <% if concern.llm_proposed? && !concern.confirmed? %>
              <%= button_to 'Confirm', confirm_concern_path(concern), method: :patch, class: 'btn btn-success btn-sm' %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="alert alert-info">
    No concerns yet. They will be created automatically as documents are categorized.
  </div>
<% end %>
