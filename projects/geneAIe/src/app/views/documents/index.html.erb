<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Documents</h1>
</div>

<% if @documents.any? %>
  <div class="table-responsive">
    <table class="table table-hover">
      <thead>
        <tr>
          <th>ID</th>
          <th>Type</th>
          <th>Concern</th>
          <th>Stage</th>
          <th>Confidence</th>
          <th>Review Required</th>
          <th>Created</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @documents.each do |document| %>
          <tr>
            <td><%= document.id %></td>
            <td><%= document.document_type || '—' %></td>
            <td>
              <% if document.concern %>
                <%= link_to document.concern.name, concern_path(document.concern) %>
              <% else %>
                —
              <% end %>
            </td>
            <td><span class="badge bg-secondary"><%= document.stage %></span></td>
            <td>
              <% if document.confidence_score %>
                <%= number_to_percentage(document.confidence_score * 100, precision: 0) %>
              <% else %>
                —
              <% end %>
            </td>
            <td>
              <% if document.review_required %>
                <span class="badge bg-warning text-dark">Yes</span>
              <% else %>
                <span class="badge bg-success">No</span>
              <% end %>
            </td>
            <td><%= document.created_at.strftime('%Y-%m-%d %H:%M') %></td>
            <td><%= link_to 'View', document_path(document), class: 'btn btn-sm btn-primary' %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="alert alert-info">
    No documents yet.
  </div>
<% end %>
