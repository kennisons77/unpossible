# syntax=docker/dockerfile:1
# Test image — includes dev/test gems and runs rspec

FROM ruby:3.3-slim

RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
      build-essential \
      libpq-dev \
      libyaml-dev \
      git \
      curl \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd --gid 1001 rails && \
    useradd --uid 1001 --gid rails --shell /bin/bash --create-home rails

WORKDIR /app

COPY app/Gemfile app/Gemfile.lock* ./
RUN bundle install --jobs 4 --retry 3

COPY app/ .

# Create DB and run migrations before tests
COPY infra/entrypoint-test.sh /entrypoint-test.sh
RUN chmod +x /entrypoint-test.sh

RUN chown -R rails:rails /app

USER rails

ENTRYPOINT ["/entrypoint-test.sh"]
CMD ["bundle", "exec", "rspec"]
