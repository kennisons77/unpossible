# syntax=docker/dockerfile:1
# Test image — uses ruby:3.3 (full) which includes build tools, libpq-dev, libyaml-dev
# Gems installed from vendor/cache (no network required)

FROM ruby:3.3

RUN groupadd --gid 1001 rails && \
    useradd --uid 1001 --gid rails --shell /bin/bash --create-home rails

WORKDIR /app

COPY web/Gemfile web/Gemfile.lock* ./
COPY web/vendor/cache ./vendor/cache
RUN bundle install --local --jobs 4

COPY web/ .
COPY specifications/ /specifications/

# Create DB and run migrations before tests
COPY infra/entrypoint-test.sh /entrypoint-test.sh
RUN chmod +x /entrypoint-test.sh

RUN chown -R rails:rails /app

USER rails

ENTRYPOINT ["/entrypoint-test.sh"]
CMD ["bundle", "exec", "rspec"]
