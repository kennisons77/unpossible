<h1>Open Questions</h1>

<form method="get">
  <label>Scope: <input name="scope" value="<%= params[:scope] %>"></label>
  <label>Level: <input name="level" value="<%= params[:level] %>"></label>
  <label>Author: <input name="author" value="<%= params[:author] %>"></label>
  <button type="submit">Filter</button>
</form>

<% if @nodes.any? %>
  <ul>
    <% @nodes.each do |node| %>
      <li>
        <%= link_to node.title.presence || "(untitled)", ledger_node_path(node.id) %>
        — <em><%= node.scope %><%= node.level ? "/#{node.level}" : "" %></em>
        · <%= node.author %>
        · <%= node.originated_at&.strftime("%Y-%m-%d") %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p>No open questions.</p>
<% end %>
