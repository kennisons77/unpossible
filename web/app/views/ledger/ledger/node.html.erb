<nav>
  <% @ancestors.each do |a| %>
    <%= link_to a.title.presence || "(untitled)", ledger_node_path(a.id) %> /
  <% end %>
  <strong><%= @node.title.presence || "(untitled)" %></strong>
</nav>

<h1><%= @node.title.presence || "(untitled)" %></h1>
<p>
  <em>
    <%= @node.kind %> · <%= @node.scope %><%= @node.level ? "/#{@node.level}" : "" %>
    · <%= @node.status %>
    · by <%= @node.author %>
    · <%= @node.originated_at&.strftime("%Y-%m-%d") %>
  </em>
</p>

<section>
  <% if @spec_content %>
    <%= render_markdown(@spec_content) %>
  <% else %>
    <%= render_markdown(@node.body) %>
  <% end %>
</section>

<% if @node.citations.present? %>
  <h2>Citations</h2>
  <ul>
    <% @node.citations.each do |c| %>
      <li><%= link_to c["label"], c["url"], target: "_blank", rel: "noopener noreferrer" %></li>
    <% end %>
  </ul>
<% end %>

<% if @children.any? %>
  <h2>Children</h2>
  <ul>
    <% @children.each do |child| %>
      <li><%= link_to child.title.presence || "(untitled)", ledger_node_path(child.id) %> — <%= child.status %></li>
    <% end %>
  </ul>
<% end %>

<% if @depends_on.any? %>
  <h2>Depends On</h2>
  <ul>
    <% @depends_on.each do |dep| %>
      <li><%= link_to dep.title.presence || "(untitled)", ledger_node_path(dep.id) %> — <%= dep.status %></li>
    <% end %>
  </ul>
<% end %>

<% if @refs.any? %>
  <h2>Refs</h2>
  <ul>
    <% @refs.each do |edge| %>
      <li><%= link_to edge.child.title.presence || "(untitled)", ledger_node_path(edge.child.id) %> (<%= edge.ref_type %>)</li>
    <% end %>
  </ul>
<% end %>

<% if @audit_events.any? %>
  <h2>Audit Trail</h2>
  <table>
    <thead>
      <tr><th>From</th><th>To</th><th>By</th><th>Reason</th><th>At</th></tr>
    </thead>
    <tbody>
      <% @audit_events.each do |event| %>
        <tr>
          <td><%= event.from_status || "—" %></td>
          <td><%= event.to_status %></td>
          <td><%= event.changed_by %></td>
          <td><%= event.reason %></td>
          <td><%= event.recorded_at.strftime("%Y-%m-%d %H:%M") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
