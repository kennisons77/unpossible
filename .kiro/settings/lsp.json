{
  "languages": {
    "ruby": {
      "name": "ruby-lsp",
      "command": "ruby-lsp",
      "args": [],
      "file_extensions": [
        "rb"
      ],
      "project_patterns": [
        "Gemfile",
        "Rakefile"
      ],
      "exclude_patterns": [
        "**/vendor/**",
        "**/tmp/**"
      ],
      "multi_workspace": false,
      "initialization_options": {},
      "request_timeout_secs": 60
    },
    "go": {
      "name": "gopls",
      "command": "gopls",
      "args": [],
      "file_extensions": [
        "go"
      ],
      "project_patterns": [
        "go.mod",
        "go.sum"
      ],
      "exclude_patterns": [
        "**/vendor/**"
      ],
      "multi_workspace": false,
      "initialization_options": {
        "usePlaceholders": true,
        "completeUnimported": true
      },
      "request_timeout_secs": 60
    }
  }
}
